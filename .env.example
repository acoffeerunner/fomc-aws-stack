# FOMC Debriefs API Keys
# Copy this file to ../.env (parent directory) and fill in your values

# YouTube Data API v3 Key
# Get one at: https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=your_youtube_api_key_here

# Google AI Studio API Key (for Gemini)
# Get one at: https://aistudio.google.com/app/apikey
GOOGLE_AI_API_KEY=your_google_ai_api_key_here

# Federal Reserve YouTube Channel ID
# Default is the official Federal Reserve channel
FED_CHANNEL_ID=UCAzhpt9DmG6PnHXjmJTvRGQ
